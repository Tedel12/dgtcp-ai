# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/dgtcp_ai

# Sécurité JWT
SECRET_KEY=votre_secret_key_tres_longue_et_complexe_ici
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Application
APP_NAME=DGTCP-AI
APP_VERSION=1.0.0
DEBUG=True

# Seuils de détection (configurables)
SEUIL_MONTANT_ELEVE=500000000
SEUIL_SCORE_RISQUE_ELEVE=75
SEUIL_SCORE_RISQUE_MOYEN=40
